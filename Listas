**Exercício 5 (Difícil) - Sistema de Atendimento com Duas Filas Resposta**

import java.util.Queue;
import java.util.ArrayDeque;

public class Main {
    public static void main(String[] args) {

        Queue<String> filaPrioritaria = new ArrayDeque<>();
        Queue<String> filaNormal = new ArrayDeque<>();

        filaPrioritaria.offer("Sr. José (80)");
        filaPrioritaria.offer("Dona Maria (70)");
        filaPrioritaria.offer("Sr. Pedro (65)");

        filaNormal.offer("João");
        filaNormal.offer("Maria");
        filaNormal.offer("Carlos");
        filaNormal.offer("Ana");
        filaNormal.offer("Marcos");

        int atendidosPrioritarios = 0;
        int atendidosNormais = 0;

        System.out.println("=== INICIANDO ATENDIMENTO ===\n");

        while (!filaPrioritaria.isEmpty() || !filaNormal.isEmpty()) {

            for (int i = 0; i < 2; i++) {

                if (!filaPrioritaria.isEmpty()) {
                    System.out.println("Atendendo (Prioritário): " + filaPrioritaria.poll());
                    atendidosPrioritarios++;
                } else {
                    System.out.println("Atendendo (Prioritário): (fila prioritária vazia)");
                }
            }

            if (!filaNormal.isEmpty()) {
                System.out.println("Atendendo (Normal): " + filaNormal.poll());
                atendidosNormais++;
            }

            System.out.println();
        }

        while (!filaNormal.isEmpty()) {
            System.out.println("Atendendo (Normal): " + filaNormal.poll());
            atendidosNormais++;
        }

        while (!filaPrioritaria.isEmpty()) {
            System.out.println("Atendendo (Prioritário): " + filaPrioritaria.poll());
            atendidosPrioritarios++;
        }

        System.out.println("=== FIM DO ATENDIMENTO ===");

        int total = atendidosPrioritarios + atendidosNormais;

        System.out.println("Total atendidos: " + total);
        System.out.println("- Prioritários: " + atendidosPrioritarios);
        System.out.println("- Normais: " + atendidosNormais);
    }
}

**Exercício 6 (Difícil) - Processador de Tarefas com Prioridade Personalizada Resposta**

import java.util.PriorityQueue;

class Tarefa implements Comparable<Tarefa> {

    String nome;
    int prioridade;
    int ordem;

    public Tarefa(String nome, int prioridade, int ordem) {
        this.nome = nome;
        this.prioridade = prioridade;
        this.ordem = ordem;
    }

    @Override
    public int compareTo(Tarefa outra) {

        if (this.prioridade != outra.prioridade) {
            return this.prioridade - outra.prioridade;
        }

        return this.ordem - outra.ordem;
    }

    @Override
    public String toString() {
        return nome + " (Prioridade: " + prioridade + ")";
    }
}

public class Main {
    public static void main(String[] args) {

        PriorityQueue<Tarefa> fila = new PriorityQueue<>();

        int contador = 0;

        fila.offer(new Tarefa("Fazer backup", 2, contador++));
        fila.offer(new Tarefa("Reiniciar servidor", 1, contador++));
        fila.offer(new Tarefa("Limpar logs", 3, contador++));
        fila.offer(new Tarefa("Atualizar sistema", 1, contador++));
        fila.offer(new Tarefa("Responder emails", 2, contador++));

        System.out.println("Tarefas adicionadas:");

        System.out.println("1. Fazer backup (Prioridade: 2)");
        System.out.println("2. Reiniciar servidor (Prioridade: 1)");
        System.out.println("3. Limpar logs (Prioridade: 3)");
        System.out.println("4. Atualizar sistema (Prioridade: 1)");
        System.out.println("5. Responder emails (Prioridade: 2)");

        System.out.println("\n=== EXECUTANDO TAREFAS ===");

        int ordemExecucao = 1;

        while (!fila.isEmpty()) {
            System.out.println(ordemExecucao + ". " + fila.poll());
            ordemExecucao++;
        }
    }
}

**Exercício 7 (Desafio) - Fila de Impressão com Cancelamento Resposta**

import java.util.LinkedList;
import java.util.Scanner;

class Documento {

    int id;
    String nomeDocumento;
    String usuario;

    public Documento(int id, String nomeDocumento, String usuario) {
        this.id = id;
        this.nomeDocumento = nomeDocumento;
        this.usuario = usuario;
    }

    @Override
    public String toString() {
        return id + "-" + nomeDocumento + "(" + usuario + ")";
    }
}

public class Main {

    public static void main(String[] args) {

        LinkedList<Documento> fila = new LinkedList<>();
        Scanner scanner = new Scanner(System.in);

        int contadorId = 1;

        while (true) {

            System.out.println("\n--- FILA DE IMPRESSÃO ---");
            System.out.println("1 - Adicionar documento");
            System.out.println("2 - Imprimir próximo");
            System.out.println("3 - Cancelar documento");
            System.out.println("4 - Ver fila");
            System.out.println("5 - Sair");

            System.out.print("Escolha: ");
            int opcao = scanner.nextInt();
            scanner.nextLine();

            if (opcao == 1) {

                System.out.print("Nome do documento: ");
                String nomeDocumento = scanner.nextLine();

                System.out.print("Usuário: ");
                String usuario = scanner.nextLine();

                Documento doc = new Documento(contadorId++, nomeDocumento, usuario);

                fila.offer(doc);

                System.out.println("Documento #" + doc.id +
                        " adicionado: " + doc.nomeDocumento +
                        " (" + doc.usuario + ")");

            } else if (opcao == 2) {

                if (fila.isEmpty()) {
                    System.out.println("Fila vazia.");
                } else {

                    Documento doc = fila.poll();

                    System.out.println("Imprimindo documento #" + doc.id +
                            ": " + doc.nomeDocumento +
                            " (" + doc.usuario + ")");
                }

            } else if (opcao == 3) {

                if (fila.isEmpty()) {
                    System.out.println("Fila vazia.");
                    continue;
                }

                System.out.print("ID do documento a cancelar: ");
                int id = scanner.nextInt();
                scanner.nextLine();

                Documento encontrado = null;

                for (Documento doc : fila) {
                    if (doc.id == id) {
                        encontrado = doc;
                        break;
                    }
                }

                if (encontrado != null) {

                    fila.remove(encontrado);

                    System.out.println("Documento #" + encontrado.id +
                            " cancelado: " + encontrado.nomeDocumento +
                            " (" + encontrado.usuario + ")");

                } else {
                    System.out.println("Documento não encontrado.");
                }

            } else if (opcao == 4) {

                System.out.println("Fila: " + fila);

            } else if (opcao == 5) {

                System.out.println("Encerrando...");
                break;

            } else {

                System.out.println("Opção inválida.");
            }
        }

        scanner.close();
    }
}

**Exercício 8 (Desafio) - Call Center com Níveis de Atendimento Resposta**

import java.util.Queue;
import java.util.ArrayDeque;
import java.util.Random;

class Chamada {

    int id;
    String descricao;
    int nivelAtual;

    public Chamada(int id, String descricao) {
        this.id = id;
        this.descricao = descricao;
        this.nivelAtual = 1;
    }
}

public class Main {

    public static void main(String[] args) {

        Queue<Chamada> nivel1 = new ArrayDeque<>();
        Queue<Chamada> nivel2 = new ArrayDeque<>();
        Queue<Chamada> nivel3 = new ArrayDeque<>();

        Random random = new Random();

        nivel1.offer(new Chamada(1, "Problema com internet"));
        nivel1.offer(new Chamada(2, "Erro no sistema"));
        nivel1.offer(new Chamada(3, "Banco de dados lento"));
        nivel1.offer(new Chamada(4, "Falha no login"));
        nivel1.offer(new Chamada(5, "Impressora offline"));

        int resolvidasNivel1 = 0;
        int resolvidasNivel2 = 0;
        int resolvidasNivel3 = 0;

        System.out.println("=== SIMULAÇÃO CALL CENTER ===\n");

        while (!nivel1.isEmpty()) {

            Chamada chamada = nivel1.poll();

            System.out.println("Atendendo Chamada #" +
                    chamada.id + ": " + chamada.descricao);

            boolean resolvida = random.nextInt(100) < 70;

            if (resolvida) {

                System.out.println("  Nível 1: RESOLVIDA\n");
                resolvidasNivel1++;

            } else {

                System.out.println("  Nível 1: NÃO RESOLVIDA → escalando para Nível 2\n");

                chamada.nivelAtual = 2;
                nivel2.offer(chamada);
            }
        }

        while (!nivel2.isEmpty()) {

            Chamada chamada = nivel2.poll();

            System.out.println("Atendendo Chamada #" +
                    chamada.id + ": " + chamada.descricao);

            boolean resolvida = random.nextInt(100) < 50;

            if (resolvida) {

                System.out.println("  Nível 2: RESOLVIDA\n");
                resolvidasNivel2++;

            } else {

                System.out.println("  Nível 2: NÃO RESOLVIDA → escalando para Nível 3\n");

                chamada.nivelAtual = 3;
                nivel3.offer(chamada);
            }
        }

        while (!nivel3.isEmpty()) {

            Chamada chamada = nivel3.poll();

            System.out.println("Atendendo Chamada #" +
                    chamada.id + ": " + chamada.descricao);

            System.out.println("  Nível 3: RESOLVIDA\n");

            resolvidasNivel3++;
        }

        int total =
                resolvidasNivel1 +
                resolvidasNivel2 +
                resolvidasNivel3;

        System.out.println("=== ESTATÍSTICAS FINAIS ===");

        System.out.println("Chamadas resolvidas no Nível 1: " +
                resolvidasNivel1);

        System.out.println("Chamadas resolvidas no Nível 2: " +
                resolvidasNivel2);

        System.out.println("Chamadas resolvidas no Nível 3: " +
                resolvidasNivel3);

        System.out.println("Total de chamadas: " + total);
    }
}
